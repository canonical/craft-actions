{
  extends: [
    'config:recommended',
  ],
  labels: [
    'dependencies',
  ],
  packageRules: [
    {
      groupName: 'patch updates',
      matchUpdateTypes: [
        'patch',
        'pin',
        'digest',
      ],
      prPriority: 3,
      automerge: true,
    },
    {
      groupName: 'GitHub Actions',
      matchManagers: [
        'github-actions',
      ],
      prPriority: 1,
    },
    {
      groupName: 'development dependencies (minor and patch)',
      groupSlug: 'dev-dependencies',
      matchDepTypes: [
        'devDependencies',
      ],
      matchUpdateTypes: [
        'minor',
        'patch',
        'pin',
        'digest',
      ],
      prPriority: -1,
      automerge: true,
    },
    {
      matchUpdateTypes: [
        'major',
      ],
      prPriority: -2,
    },
    {
      matchDepTypes: [
        'devDependencies',
      ],
      matchUpdateTypes: [
        'major',
      ],
      prPriority: -3,
    },
  ],
  timezone: 'Etc/UTC',
  automergeSchedule: [
    'after 1 am and before 7 am',
  ],
  schedule: [
    'every weekend',
  ],
  prConcurrentLimit: 5,
  prCreation: 'not-pending',
  prNotPendingHours: 4,
  prHourlyLimit: 1,
  minimumReleaseAge: '2 days',
}
