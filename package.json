{
  "name": "craft-actions",
  "version": "0.0.1",
  "description": "A set of GitHub actions for using craft tools (like Snapcraft and Rockcraft)",
  "private": true,
  "type": "module",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "pnpm node build.mjs src/rockcraft-pack.ts dist/rockcraft-pack/index.js",
    "test": "vitest run",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint .; tsc --noEmit",
    "lint-fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canonical/craft-actions.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/canonical/craft-actions/issues"
  },
  "homepage": "https://github.com/canonical/craft-actions#readme",
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
